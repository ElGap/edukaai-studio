[pylint]
# Pylint configuration for catching common bugs

[MASTER]
# Add the src directory to the path
init-hook='import sys; sys.path.insert(0, "src")'

[MESSAGES CONTROL]
# Enable all checks, then disable specific noisy ones
enable=all
disable=
    C0103,  # Invalid name (snake_case) - we follow our own conventions
    C0114,  # Missing module docstring
    C0115,  # Missing class docstring
    C0116,  # Missing function docstring
    C0301,  # Line too long - we use 100 chars, not 80
    R0903,  # Too few public methods (dataclasses, etc.)
    R0913,  # Too many arguments
    R0914,  # Too many local variables
    R0915,  # Too many statements
    W0511,  # TODO/FIXME notes
    W0703,  # Catching too general exception (we use this intentionally)

[REPORTS]
# Report format
output-format=text
reports=yes

[BASIC]
# Naming conventions
variable-rgx=[a-z_][a-z0-9_]{0,50}$
argument-rgx=[a-z_][a-z0-9_]{0,50}$

[SIMILARITIES]
# Don't complain about similar code
min-similarity-lines=10

[TYPECHECK]
# Ignore certain imports that pylint can't understand
generated-members=numpy.*,torch.*,mlx.*,gradio.*,transformers.*

[DESIGN]
# Maximum values
max-args=10
max-locals=30
max-returns=10
max-branches=20
max-statements=100
max-parents=7
max-attributes=15
max-public-methods=50
max-module-lines=2000

[EXCEPTIONS]
# Overgeneral exceptions that should be flagged
overgeneral-exceptions=Exception

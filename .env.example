# EdukaAI Studio - Environment Configuration

# ============================================
# SERVER CONFIGURATION
# ============================================

# Backend server host (default: 127.0.0.1)
# Set to 0.0.0.0 only if you need remote access (not recommended)
EDUKAAI_HOST=127.0.0.1

# Backend server port (default: 8000)
EDUKAAI_PORT=8000

# Frontend development server port (default: 3030)
VITE_PORT=3030

# Backend API URL for frontend proxy (default: http://localhost:8000)
VITE_API_URL=http://localhost:8000

# WebSocket URL for frontend (default: ws://localhost:8000)
VITE_WS_URL=ws://localhost:8000

# ============================================
# DATABASE
# ============================================

# SQLite database URL (default: sqlite:///./storage/app/edukaai.db)
EDUKAAI_DATABASE_URL=sqlite:///./storage/app/edukaai.db

# ============================================
# STORAGE
# ============================================

# Base storage path (default: ./storage)
EDUKAAI_STORAGE_PATH=./storage

# Maximum storage in GB (default: 50)
EDUKAAI_MAX_STORAGE_GB=50

# ============================================
# SECURITY
# ============================================

# Allow remote connections (default: false)
# WARNING: Only set to true if you understand the security implications
EDUKAAI_ALLOW_REMOTE=false

# ============================================
# MLX (Machine Learning)
# ============================================

# Device for MLX (default: gpu, options: gpu, cpu)
EDUKAAI_MLX_DEVICE=gpu

# GPU memory limit in MB (optional, default: no limit)
# EDUKAAI_MLX_GPU_MEMORY_LIMIT_MB=8192

# ============================================
# HUGGINGFACE
# ============================================

# HuggingFace API token (optional)
# Set this to download private models and get higher rate limits
# Get your token from: https://huggingface.co/settings/tokens
# EDUKAAI_HF_TOKEN=your-hf-token-here

# ============================================
# LOGGING
# ============================================

# Log level (default: INFO, options: DEBUG, INFO, WARNING, ERROR)
EDUKAAI_LOG_LEVEL=INFO

# Log file path (default: ./storage/app/logs/master.log)
EDUKAAI_LOG_FILE=./storage/app/logs/master.log

# ============================================
# TRAINING LIMITS
# ============================================

# Maximum dataset samples (default: 10000)
EDUKAAI_MAX_DATASET_SAMPLES=10000

# Maximum context length (default: 4096)
EDUKAAI_MAX_CONTEXT_LENGTH=4096

# Maximum concurrent training runs (default: 1)
EDUKAAI_MAX_CONCURRENT_RUNS=1

# ============================================
# PERSISTENT STORAGE (Survives App Reinstalls)
# ============================================

# Model cache directory - downloaded base models are stored here
# Default: ~/.edukaai/models (in user's home directory)
# Changing this allows you to use external drives or different locations
# EDUKAAI_MODEL_CACHE_DIR=/path/to/your/model/cache

# Training output directory - training runs, adapters, and exports
# Default: ~/.edukaai/training (in user's home directory)
# This persists across app reinstalls so you can continue training after reinstall
# EDUKAAI_TRAINING_OUTPUT_DIR=/path/to/your/training/outputs

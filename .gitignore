# Build artifacts
build/
dist/
*.tar.gz
*.zip
*.app/
*.command
*.egg-info/
install-edukai.sh
install.log

# Backend - Python
backend/.venv/
backend/__pycache__/
backend/**/*.pyc
backend/**/*.pyo
backend/**/*.pyd
backend/.Python
backend/*.so
backend/*.egg
dist/
build/

# Frontend - Node.js
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/*.local

# Storage - User Data & Generated Files (NEVER commit these)
# Datasets uploaded by users
backend/storage/datasets/*
!backend/storage/datasets/.gitkeep

# Training runs (models, checkpoints, logs, configs)
backend/storage/runs/*
!backend/storage/runs/.gitkeep
backend/storage/runs/**/logs/
backend/storage/runs/**/*.log

# Application data (SQLite DB, logs, cache, temp files)
backend/storage/app/*.db
backend/storage/app/*.db-journal
backend/storage/app/logs/*
backend/storage/app/logs/**/
backend/storage/app/cache/*
backend/storage/app/temp/*
backend/storage/db/*.db
backend/storage/db/*.db-journal

# Model exports
backend/storage/exports/*
!backend/storage/exports/.gitkeep

# Environment files (may contain secrets)
.env
.env.*
!.env.example
backend/.env
backend/.env.local
frontend/.env
frontend/.env.local

# Logs - All log files anywhere in the project
*.log
logs/
**/logs/
**/logs/archive/
**/*.log.*

# Coverage and test artifacts
.coverage
htmlcov/
.tox/
.pytest_cache/
backend/.coverage
backend/htmlcov/
backend/.tox/
backend/.pytest_cache/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
**/.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.temp
*.bak

